{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "share": "disabled",
  "mcp": {},
  "model": "azure/gpt-5.4",
  "small_model": "azure/gpt-5.3-codex",
  "default_agent": "build",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "*.key": "deny",
      "*.pem": "deny",
      "*.p12": "deny",
      "*.pfx": "deny",
      "id_rsa*": "deny",
      "id_ed25519*": "deny",
      "**/*secret*": "ask",
      "**/*token*": "ask"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "edit": {
      "*": "ask",
      "sources/**": "allow",
      "pipelines/**": "allow",
      "scripts/**": "allow"
    },
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "rm -rf*": "deny",
      "rm -r*": "deny",
      "curl * | bash*": "deny",
      "wget * | bash*": "deny"
    },
    "external_directory": "allow",
    "todowrite": "allow"
  },
  "enabled_providers": ["azure", "github-copilot", "anthropic"],
  "instructions": [
    "AGENTS.md",
    "skills/embedded-c-patterns/SKILL.md",
    "skills/coding-standards/SKILL.md",
    "skills/tdd-workflow/SKILL.md",
    "skills/security-review/SKILL.md",
    "skills/verification-loop/SKILL.md",
    "skills/strategic-compact/SKILL.md"
  ],
  "plugin": [
    "opencode-claude-auth@latest"
  ]
}
